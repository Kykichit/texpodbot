# Production template. Copy on the server and fill through server env or a
# secret manager. Do not commit real production values.
APP_ENV=production
LOG_LEVEL=INFO
BOT_MODE=telegram

# Use private service hostnames or managed service URLs, not localhost inside
# containers. Prefer DB_* so credentials are not duplicated inside URLs.
DB_SCHEME=postgresql+asyncpg
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DATABASE_URL=
REDIS_SCHEME=redis
REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=

# Telegram production credentials.
TELEGRAM_BOT_TOKEN=
TELEGRAM_PROXY_URL=
TELEGRAM_SUPPORT_GROUP_ID=

# Use either Telegram webhook mode or exactly one polling process.
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=

# HTTP server bind inside the container.
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEBHOOK_BASE_URL=

# Optional integrations.
SENTRY_DSN=
GITHUB_TOKEN=
GITHUB_REPO=

# Chatwoot production integration.
CHATWOOT_ENABLED=true
CHATWOOT_BASE_URL=
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=
CHATWOOT_WEBHOOK_SECRET=

# Must stay false in production/staging.
CHATWOOT_ALLOW_UNSIGNED_LOCAL_WEBHOOKS=false

# MAX placeholders.
MAX_BOT_TOKEN=
MAX_API_BASE_URL=https://platform-api.max.ru

# Runtime settings.
EXTERNAL_API_TIMEOUT_SECONDS=10
LIVE_TESTS_ENABLED=false
LIVE_TEST_TELEGRAM_CHAT_ID=
LIVE_TEST_MAX_CHAT_ID=
