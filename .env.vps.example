# All-in-one VPS taskbot env. Copy to .env.vps and fill on the VPS only.
VPS_ENV_FILE=.env.vps
CHATWOOT_ENV_FILE=.env.chatwoot.production
TASKBOT_IMAGE=taskbot:local
CHATWOOT_IMAGE=chatwoot/chatwoot:v4.1.0

# Domains served by Caddy.
BOT_DOMAIN=
CHATWOOT_DOMAIN=
ACME_EMAIL=

# Shared PostgreSQL container. The init script creates separate DBs/users.
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_SUPER_PASSWORD=
TASKBOT_DB=taskbot
TASKBOT_DB_USER=taskbot
TASKBOT_DB_PASSWORD=
CHATWOOT_DB=chatwoot
CHATWOOT_DB_USER=chatwoot
CHATWOOT_DB_PASSWORD=

# Taskbot runtime.
APP_ENV=production
LOG_LEVEL=INFO
BOT_MODE=telegram
DB_SCHEME=postgresql+asyncpg
DB_HOST=postgres
DB_PORT=5432
DB_NAME=taskbot
DB_USER=taskbot
DB_PASSWORD=
DATABASE_URL=
REDIS_SCHEME=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEBHOOK_BASE_URL=

# Telegram production webhook mode.
TELEGRAM_BOT_TOKEN=
TELEGRAM_PROXY_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_SUPPORT_GROUP_ID=

# Chatwoot operator desk integration.
CHATWOOT_ENABLED=true
CHATWOOT_BASE_URL=
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=
CHATWOOT_WEBHOOK_SECRET=
CHATWOOT_ALLOW_UNSIGNED_LOCAL_WEBHOOKS=false

# Optional integrations and compatibility placeholders.
SENTRY_DSN=
GITHUB_TOKEN=
GITHUB_REPO=
MAX_BOT_TOKEN=
MAX_API_BASE_URL=https://platform-api.max.ru
EXTERNAL_API_TIMEOUT_SECONDS=10
LIVE_TESTS_ENABLED=false
LIVE_TEST_TELEGRAM_CHAT_ID=
LIVE_TEST_MAX_CHAT_ID=
