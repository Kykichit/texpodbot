# Dummy env for safe all-in-one VPS Compose validation.
VPS_ENV_FILE=.env.vps.compose-check.example
CHATWOOT_ENV_FILE=.env.chatwoot.compose-check.example
TASKBOT_IMAGE=taskbot:compose-check
CHATWOOT_IMAGE=chatwoot/chatwoot:v4.1.0
BOT_DOMAIN=bot.example.test
CHATWOOT_DOMAIN=chatwoot.example.test
ACME_EMAIL=admin@example.test
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_SUPER_PASSWORD=dummy-postgres-password
TASKBOT_DB=taskbot
TASKBOT_DB_USER=taskbot
TASKBOT_DB_PASSWORD=dummy-taskbot-password
CHATWOOT_DB=chatwoot
CHATWOOT_DB_USER=chatwoot
CHATWOOT_DB_PASSWORD=dummy-chatwoot-password
APP_ENV=production
LOG_LEVEL=INFO
BOT_MODE=telegram
DB_SCHEME=postgresql+asyncpg
DB_HOST=postgres
DB_PORT=5432
DB_NAME=taskbot
DB_USER=taskbot
DB_PASSWORD=dummy-taskbot-password
REDIS_SCHEME=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEBHOOK_BASE_URL=https://bot.example.test
TELEGRAM_BOT_TOKEN=dummy-token
TELEGRAM_PROXY_URL=
TELEGRAM_WEBHOOK_SECRET=dummy-telegram-secret
TELEGRAM_WEBHOOK_URL=https://bot.example.test/telegram/webhook
TELEGRAM_SUPPORT_GROUP_ID=-1000000000000
CHATWOOT_ENABLED=true
CHATWOOT_BASE_URL=https://chatwoot.example.test
CHATWOOT_API_TOKEN=dummy-chatwoot-token
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1
CHATWOOT_WEBHOOK_SECRET=dummy-chatwoot-secret
CHATWOOT_ALLOW_UNSIGNED_LOCAL_WEBHOOKS=false
SENTRY_DSN=
GITHUB_TOKEN=
GITHUB_REPO=
MAX_BOT_TOKEN=
MAX_API_BASE_URL=https://platform-api.max.ru
EXTERNAL_API_TIMEOUT_SECONDS=10
LIVE_TESTS_ENABLED=false
LIVE_TEST_TELEGRAM_CHAT_ID=
LIVE_TEST_MAX_CHAT_ID=
