# Dummy env for safe `docker compose config` checks.
APP_ENV=test
COMPOSE_ENV_FILE=.env.compose-check.example
LOG_LEVEL=INFO
BOT_MODE=telegram

# Dummy service URLs for Compose validation.
DB_SCHEME=postgresql+asyncpg
DB_HOST=postgres
DB_PORT=5432
DB_NAME=support
DB_USER=support
DB_PASSWORD=dummy-postgres-password
REDIS_SCHEME=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
POSTGRES_DB=support
POSTGRES_USER=support
POSTGRES_PASSWORD=dummy-postgres-password
POSTGRES_PORT=5432

# Dummy Telegram values. Not valid for live use.
TELEGRAM_BOT_TOKEN=dummy-token
TELEGRAM_PROXY_URL=
TELEGRAM_WEBHOOK_SECRET=dummy-secret
TELEGRAM_WEBHOOK_URL=https://example.test/telegram/webhook
TELEGRAM_SUPPORT_GROUP_ID=-1000000000000

# HTTP server settings.
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEBHOOK_BASE_URL=https://example.test

# MAX placeholders.
MAX_BOT_TOKEN=
MAX_API_BASE_URL=https://platform-api.max.ru

# Optional integrations are disabled for safe config output.
EXTERNAL_API_TIMEOUT_SECONDS=10
SENTRY_DSN=
GITHUB_TOKEN=
GITHUB_REPO=
CHATWOOT_ENABLED=false
CHATWOOT_BASE_URL=https://chatwoot.example.test
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=
CHATWOOT_WEBHOOK_SECRET=
CHATWOOT_ALLOW_UNSIGNED_LOCAL_WEBHOOKS=false

# Live tests are disabled for CI/docs checks.
LIVE_TESTS_ENABLED=false
LIVE_TEST_TELEGRAM_CHAT_ID=
LIVE_TEST_MAX_CHAT_ID=
