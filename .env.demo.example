# Demo environment. Safe placeholders only.
APP_ENV=demo
COMPOSE_PROJECT_NAME=taskbot-demo
LOG_LEVEL=INFO
BOT_MODE=telegram

# Host-mode defaults: Python on host, PostgreSQL/Redis in Docker.
DB_SCHEME=postgresql+asyncpg
DB_HOST=localhost
DB_PORT=15432
DB_NAME=support_demo
DB_USER=support_demo
DB_PASSWORD=support_demo
POSTGRES_PORT=15432
REDIS_SCHEME=redis
REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_DB=0
REDIS_PASSWORD=
WEB_HOST=127.0.0.1
WEB_PORT=8080

# Demo placeholders. Replace only with a test bot after live-test approval.
TELEGRAM_BOT_TOKEN=0000000000:demo_token_not_real
TELEGRAM_PROXY_URL=
TELEGRAM_SUPPORT_GROUP_ID=-1000000000000
TELEGRAM_WEBHOOK_SECRET=demo-webhook-secret
TELEGRAM_WEBHOOK_URL=

# MAX placeholders.
MAX_BOT_TOKEN=
MAX_API_BASE_URL=https://platform-api.max.ru

# Optional public base URL for webhook mode.
WEBHOOK_BASE_URL=

# External API timeout.
EXTERNAL_API_TIMEOUT_SECONDS=10

# Optional integrations. Do not put production secrets here.
SENTRY_DSN=
GITHUB_TOKEN=
GITHUB_REPO=

# Chatwoot demo integration. Fill ids/tokens only for local self-host Chatwoot.
CHATWOOT_ENABLED=false
CHATWOOT_BASE_URL=http://host.docker.internal:3000
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=
CHATWOOT_WEBHOOK_SECRET=

# Local/demo-only fallback for unsigned local Chatwoot webhooks.
CHATWOOT_ALLOW_UNSIGNED_LOCAL_WEBHOOKS=true

# Local helper value used in docs and scripts.
CHATWOOT_WEBHOOK_URL=http://host.docker.internal:18080/chatwoot/webhook

# Local self-host Chatwoot helper. Safe defaults for local/demo only.
CHATWOOT_LOCAL_DIR=C:\chatwoot-local
CHATWOOT_LOCAL_COMPOSE_FILE=docker-compose.chatwoot.yml
CHATWOOT_LOCAL_BASE_URL=http://localhost:3000

# Live tests are opt-in only.
LIVE_TESTS_ENABLED=false
LIVE_TEST_TELEGRAM_CHAT_ID=
LIVE_TEST_MAX_CHAT_ID=
