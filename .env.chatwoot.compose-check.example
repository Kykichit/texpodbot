# Dummy Chatwoot env for safe all-in-one VPS Compose validation.
RAILS_ENV=production
NODE_ENV=production
SECRET_KEY_BASE=dummy-chatwoot-secret-key-base
FRONTEND_URL=https://chatwoot.example.test
INSTALLATION_ENV=docker
RAILS_LOG_TO_STDOUT=true
LOG_LEVEL=info

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=dummy-chatwoot-password
DATABASE_URL=postgresql://chatwoot:dummy-chatwoot-password@postgres:5432/chatwoot

REDIS_URL=redis://redis:6379/1

ENABLE_ACCOUNT_SIGNUP=true
FORCE_SSL=true
