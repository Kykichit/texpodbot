# Application environment: local, demo, test, staging, production.
APP_ENV=local

# Log level used by the app logger.
LOG_LEVEL=INFO

# Bot runtime mode: telegram, max, or both.
BOT_MODE=telegram

# PostgreSQL is the source of truth for tickets, messages, events, and refs.
# The app derives DATABASE_URL from these values. DATABASE_URL may still be set
# directly for managed databases, but do not duplicate both forms in one env.
DB_SCHEME=postgresql+asyncpg
DB_HOST=postgres
DB_PORT=5432
DB_NAME=support
DB_USER=support
DB_PASSWORD=

# Local Compose PostgreSQL settings. POSTGRES_PASSWORD should match DB_PASSWORD.
POSTGRES_DB=support
POSTGRES_USER=support
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# Redis is used for runtime/cache/state dependencies.
REDIS_SCHEME=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Telegram bot token. Leave empty in templates; use a test bot for demos.
TELEGRAM_BOT_TOKEN=

# Optional Telegram HTTP proxy URL.
TELEGRAM_PROXY_URL=

# Secret for Telegram webhook mode.
TELEGRAM_WEBHOOK_SECRET=

# Public HTTPS Telegram webhook URL when webhook mode is used.
TELEGRAM_WEBHOOK_URL=

# Support group/chat id for operator handoff.
TELEGRAM_SUPPORT_GROUP_ID=

# HTTP server bind address and port.
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Optional public base URL used by webhook integrations.
WEBHOOK_BASE_URL=

# Optional Sentry DSN. Do not commit real values.
SENTRY_DSN=

# Optional GitHub integration placeholders. Do not commit real tokens.
GITHUB_TOKEN=
GITHUB_REPO=

# Enable Chatwoot support desk integration.
CHATWOOT_ENABLED=false

# Chatwoot base URL. In containers, do not use localhost for another service.
CHATWOOT_BASE_URL=

# Chatwoot API token. Required when Chatwoot is enabled.
CHATWOOT_API_TOKEN=

# Chatwoot account and API inbox ids.
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=

# Chatwoot webhook secret. Required for production/staging signed webhooks.
CHATWOOT_WEBHOOK_SECRET=

# Local/demo-only unsigned webhook fallback. Keep false outside local/demo.
CHATWOOT_ALLOW_UNSIGNED_LOCAL_WEBHOOKS=false

# MAX compatibility placeholders.
MAX_BOT_TOKEN=
MAX_API_BASE_URL=https://platform-api.max.ru

# Timeout for external API calls.
EXTERNAL_API_TIMEOUT_SECONDS=10

# Optional live tests. Keep disabled in CI and docs by default.
LIVE_TESTS_ENABLED=false
LIVE_TEST_TELEGRAM_CHAT_ID=
LIVE_TEST_MAX_CHAT_ID=
