# All-in-one VPS Chatwoot env. Copy to .env.chatwoot.production on the VPS.
RAILS_ENV=production
NODE_ENV=production
SECRET_KEY_BASE=
FRONTEND_URL=
INSTALLATION_ENV=docker
RAILS_LOG_TO_STDOUT=true
LOG_LEVEL=info

# Chatwoot PostgreSQL database created by deploy/postgres/init.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=
DATABASE_URL=

# Shared Redis service. Chatwoot uses DB 1; taskbot uses DB 0.
REDIS_URL=redis://redis:6379/1

# Keep signup enabled for first bootstrap, then disable on a real pilot.
ENABLE_ACCOUNT_SIGNUP=true
FORCE_SSL=true
