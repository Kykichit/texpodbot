# Application
APP_ENV=local
LOG_LEVEL=INFO

# Bot runtime mode: telegram, max, both
BOT_MODE=telegram

# Host app + Dockerized PostgreSQL/Redis.
DB_SCHEME=postgresql+asyncpg
DB_HOST=localhost
DB_PORT=5432
DB_NAME=support
DB_USER=support
DB_PASSWORD=
DATABASE_URL=
REDIS_SCHEME=redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_PROXY_URL=
TELEGRAM_WEBHOOK_SECRET=local-dev-secret
TELEGRAM_WEBHOOK_URL=
TELEGRAM_SUPPORT_GROUP_ID=

# Webhook HTTP server on Windows host
WEB_HOST=127.0.0.1
WEB_PORT=8080

# Optional integrations
SENTRY_DSN=
GITHUB_TOKEN=
GITHUB_REPO=

# Chatwoot support desk integration
CHATWOOT_ENABLED=false
CHATWOOT_BASE_URL=http://localhost:3000
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=
CHATWOOT_WEBHOOK_SECRET=

# MAX compatibility placeholders
MAX_BOT_TOKEN=
MAX_API_BASE_URL=https://platform-api.max.ru

# External APIs
EXTERNAL_API_TIMEOUT_SECONDS=10

# Optional live tests. Keep disabled unless explicitly approved.
LIVE_TESTS_ENABLED=false
LIVE_TEST_TELEGRAM_CHAT_ID=
LIVE_TEST_MAX_CHAT_ID=
